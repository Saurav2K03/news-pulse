# News Pulse backend configuration (copy to .env and adjust)
PORT=4000
# Path to the SQLite DB shared with the Python scraper
NEWSPULSE_DB_PATH=../data/newspulse.db
# Python interpreter used to run the pipeline (use the scraper venv locally)
PYTHON_BIN=../scraper/.venv/bin/python
# Path to the pipeline entry script
PIPELINE_SCRIPT=../scraper/run_pipeline.py
# Allowed CORS origin (set to your frontend URL in production)
CORS_ORIGIN=*
